<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= thread.title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        async function vote(url, scoreElementId) {
            try {
                const response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });
                const data = await response.json();
                if (data.success) {
                    document.getElementById(scoreElementId).textContent = data.score;
                }
            } catch (error) {
                console.error('Error voting:', error);
            }
            return false;
        }
    </script>
</head>
<body class="bg-gray-50">
    <!-- Header -->
    <div class="bg-white border-b sticky top-0 z-10">
        <div class="container mx-auto px-4 py-3 max-w-5xl">
            <a href="/" class="text-gray-600 hover:text-gray-900 text-sm">&larr; Back to Forum</a>
        </div>
    </div>

    <div class="container mx-auto px-4 py-4 max-w-5xl">
        <!-- Original Post -->
        <div class="bg-white rounded border mb-4">
            <!-- Post Header -->
            <div class="px-4 pt-3 pb-2">
                <div class="flex items-center text-xs text-gray-500 mb-2">
                    <span class="font-semibold text-gray-700">u/<%= thread.author %></span>
                    <span class="mx-1">•</span>
                    <span><%= new Date(thread.createdAt).toLocaleDateString() %></span>
                </div>
                <h1 class="text-xl font-bold text-gray-900 mb-3"><%= thread.title %></h1>
                <div class="text-sm text-gray-700 mb-2 whitespace-pre-wrap"><%= thread.content %></div>
            </div>

            <!-- Post Image -->
            <% if (thread.image) { %>
                <div class="px-4 pb-2">
                    <img src="<%= thread.image %>" alt="Post image"
                         class="w-full max-h-96 object-contain bg-gray-100 rounded cursor-pointer"
                         onclick="window.open(this.src, '_blank')">
                </div>
            <% } %>

            <!-- Post Footer -->
            <div class="px-4 py-2 flex items-center gap-4 text-xs text-gray-500 border-t">
                <!-- Vote Section -->
                <div class="flex items-center gap-1 hover:bg-gray-100 px-2 py-1 rounded">
                    <button onclick="vote('/threads/<%= thread._id %>/upvote', 'thread-score'); return false;" class="text-gray-500 hover:text-orange-500">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M10 3l7 7h-4v7H7v-7H3l7-7z"/>
                        </svg>
                    </button>
                    <span id="thread-score" class="font-semibold text-gray-700 mx-1"><%= thread.upvotes - thread.downvotes %></span>
                    <button onclick="vote('/threads/<%= thread._id %>/downvote', 'thread-score'); return false;" class="text-gray-500 hover:text-gray-700">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M10 17l-7-7h4V3h6v7h4l-7 7z"/>
                        </svg>
                    </button>
                </div>

                <span class="flex items-center gap-1">
                    <span>💬</span>
                    <span><%= thread.replies.length %> Comments</span>
                </span>
                <button class="flex items-center gap-1 hover:bg-gray-100 px-2 py-1 rounded">
                    <span>🔗</span>
                    <span>Share</span>
                </button>
            </div>
        </div>

        <!-- Comments Section -->
        <div class="bg-white rounded border mb-4">
            <div class="px-4 py-3 border-b">
                <h2 class="text-sm font-semibold text-gray-700">Comments (<%= thread.replies.length %>)</h2>
            </div>

            <% if (thread.replies.length === 0) { %>
                <p class="text-gray-500 text-center py-8 text-sm">No comments yet. Be the first to comment!</p>
            <% } %>

            <div>
                <% thread.replies.forEach((reply, index) => { %>
                    <div class="px-4 py-3 <%= index !== thread.replies.length - 1 ? 'border-b' : '' %>">
                        <div class="flex gap-2">
                            <!-- Comment Content -->
                            <div class="flex-1">
                                <div class="flex items-center gap-2 mb-1">
                                    <span class="text-xs font-semibold text-gray-700">u/<%= reply.author %></span>
                                    <span class="text-xs text-gray-400">•</span>
                                    <span class="text-xs text-gray-400"><%= new Date(reply.createdAt).toLocaleDateString() %></span>
                                </div>
                                <p class="text-sm text-gray-800 whitespace-pre-wrap mb-2"><%= reply.content %></p>
                                <% if (reply.image) { %>
                                    <div class="mt-2 mb-2">
                                        <img src="<%= reply.image %>" alt="Comment image"
                                             class="max-w-md w-full h-auto rounded border cursor-pointer hover:opacity-90"
                                             onclick="window.open(this.src, '_blank')">
                                    </div>
                                <% } %>
                                <div class="flex items-center gap-3 text-xs text-gray-500">
                                    <button class="hover:bg-gray-100 px-2 py-1 rounded">Reply</button>
                                    <button class="hover:bg-gray-100 px-2 py-1 rounded">Share</button>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>

        <!-- Add Comment Form -->
        <div class="bg-white rounded border">
            <div class="px-4 py-3 border-b">
                <h2 class="text-sm font-semibold text-gray-700">Add a Comment</h2>
            </div>
            <form action="/threads/<%= thread._id %>/reply" method="POST" enctype="multipart/form-data" class="p-4">
                <div class="mb-3">
                    <input type="text" name="author" required placeholder="Username" value="<%= currentUser || '' %>"
                           class="w-full px-3 py-2 text-sm border rounded focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent">
                    <% if (currentUser) { %>
                        <p class="text-xs text-gray-500 mt-1">Commenting as: <%= currentUser %></p>
                    <% } %>
                </div>

                <div class="mb-3">
                    <textarea name="content" rows="4" required placeholder="What are your thoughts?"
                              class="w-full px-3 py-2 text-sm border rounded focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent resize-none"></textarea>
                </div>

                <div class="mb-3">
                    <label class="block text-xs text-gray-600 mb-1">Upload Image (Optional)</label>
                    <input type="file" name="image" accept="image/*"
                           class="w-full px-3 py-2 text-sm border rounded focus:outline-none focus:ring-2 focus:ring-orange-500">
                    <p class="text-xs text-gray-500 mt-1">Max size: 5MB. Formats: JPG, PNG, GIF</p>
                </div>

                <div class="flex justify-end">
                    <button type="submit" class="bg-orange-500 text-white px-6 py-2 rounded-full hover:bg-orange-600 font-semibold text-sm">
                        Comment
                    </button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>

