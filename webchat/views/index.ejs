<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Simple Forum</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        async function vote(url, scoreElementId) {
            try {
                const response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });
                const data = await response.json();
                if (data.success) {
                    document.getElementById(scoreElementId).textContent = data.score;
                    // Reload page after a short delay to show updated order
                    setTimeout(() => {
                        window.location.reload();
                    }, 300);
                }
            } catch (error) {
                console.error('Error voting:', error);
            }
            return false;
        }
    </script>
</head>
<body class="bg-gray-50">
    <!-- Header -->
    <div class="bg-white border-b sticky top-0 z-10">
        <div class="container mx-auto px-4 py-3 max-w-5xl flex justify-between items-center">
            <h1 class="text-xl font-bold text-gray-900">Simple Forum</h1>
            <a href="/new" class="bg-orange-500 text-white px-4 py-2 rounded-full hover:bg-orange-600 font-semibold text-sm">
                Create Post
            </a>
        </div>
    </div>

    <div class="container mx-auto px-4 py-4 max-w-5xl">

        <!-- Posts Feed -->
        <div class="space-y-3">
            <% if (threads.length === 0) { %>
                <div class="bg-white rounded border p-6 text-center text-gray-500">
                    No posts yet. Be the first to create one!
                </div>
            <% } %>

            <% threads.forEach(thread => { %>
                <div class="bg-white rounded border hover:border-gray-400 transition">
                    <!-- Post Content -->
                    <div class="px-4 pt-3 pb-2">
                        <div class="flex items-center text-xs text-gray-500 mb-2">
                            <span class="font-semibold text-gray-700">u/<%= thread.author %></span>
                            <span class="mx-1">•</span>
                            <span><%= new Date(thread.createdAt).toLocaleDateString() %></span>
                        </div>
                        <a href="/threads/<%= thread._id %>">
                            <h2 class="text-lg font-semibold text-gray-900 hover:text-gray-700 mb-2">
                                <%= thread.title %>
                            </h2>
                        </a>
                        <p class="text-sm text-gray-700 mb-2"><%= thread.content.substring(0, 200) %><%= thread.content.length > 200 ? '...' : '' %></p>
                    </div>

                    <!-- Post Image -->
                    <% if (thread.image) { %>
                        <div class="px-4 pb-2">
                            <a href="/threads/<%= thread._id %>">
                                <img src="<%= thread.image %>" alt="Post image"
                                     class="w-full max-h-96 object-contain bg-gray-100 rounded cursor-pointer">
                            </a>
                        </div>
                    <% } %>

                    <!-- Post Footer -->
                    <div class="px-4 py-2 flex items-center gap-4 text-xs text-gray-500 border-t">
                        <!-- Vote Section -->
                        <div class="flex items-center gap-1 hover:bg-gray-100 px-2 py-1 rounded">
                            <button onclick="vote('/threads/<%= thread._id %>/upvote', 'thread-score-<%= thread._id %>'); return false;" class="text-gray-500 hover:text-orange-500">
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                    <path d="M10 3l7 7h-4v7H7v-7H3l7-7z"/>
                                </svg>
                            </button>
                            <span id="thread-score-<%= thread._id %>" class="font-semibold text-gray-700 mx-1"><%= thread.upvotes - thread.downvotes %></span>
                            <button onclick="vote('/threads/<%= thread._id %>/downvote', 'thread-score-<%= thread._id %>'); return false;" class="text-gray-500 hover:text-gray-700">
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                    <path d="M10 17l-7-7h4V3h6v7h4l-7 7z"/>
                                </svg>
                            </button>
                        </div>

                        <a href="/threads/<%= thread._id %>" class="flex items-center gap-1 hover:bg-gray-100 px-2 py-1 rounded">
                            <span>💬</span>
                            <span><%= thread.replies.length %> Comments</span>
                        </a>
                        <button class="flex items-center gap-1 hover:bg-gray-100 px-2 py-1 rounded">
                            <span>🔗</span>
                            <span>Share</span>
                        </button>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</body>
</html>

